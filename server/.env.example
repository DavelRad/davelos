# ----------------------------------------------------------------------------
# "Ask Davel" backend environment.
#
# For LOCAL dev: copy to `.env` (gitignored) and `export $(grep -v '^#' .env | xargs)`
# before `uvicorn main:app --port 8080`, OR pass them inline.
#
# In PRODUCTION these are NOT a file — ANTHROPIC_API_KEY lives in GCP Secret
# Manager and is mounted into Cloud Run via `--set-secrets`. Never commit a key.
# ----------------------------------------------------------------------------

# Required for real answers. Without it the bot runs in "offline" mode and the
# front end falls back to its built-in canned answers.
ANTHROPIC_API_KEY=

# Model + answer length (optional; sensible defaults baked in).
ANTHROPIC_MODEL=claude-haiku-4-5
ASK_MAX_TOKENS=512

# Rate limiting (optional; defaults are tuned for a portfolio).
RL_WINDOW=30          # per-IP burst window, seconds
RL_BURST=6            # max requests per window per IP
RL_IP_DAY=50          # max requests per day per IP
RL_GLOBAL_DAY=1000    # hard global ceiling per day (budget guard)

# Spotify "now playing" (optional — mock data shows until these are set).
# Get the refresh token with: node scripts/spotify-auth.mjs
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
